DJANGO_ENV=development
DEBUG=1
ALLOW_EMBEDDED_PREVIEW=1
SECRET_KEY=dev-only-secret-key-change-for-shared-environments
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
DB_ENGINE=django.db.backends.postgresql
DB_NAME=journal_db
DB_USER=journal_user
DB_PASSWORD=journal_password
DB_HOST=db
DB_PORT=5432
WAIT_FOR_DB=1
POSTGRES_DB=journal_db
POSTGRES_USER=journal_user
POSTGRES_PASSWORD=journal_password
APP_IMAGE=cadet-journal:web
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.local
DJANGO_SUPERUSER_PASSWORD=change-me-local-admin-password
DATA_TOOLS_PASSWORD=change-me-local-data-tools-password
ENABLE_DESTRUCTIVE_DATA_TOOLS=1
TRUST_X_FORWARDED_FOR=0
TRUSTED_PROXY_COUNT=1
