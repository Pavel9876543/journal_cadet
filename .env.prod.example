DJANGO_ENV=production
DEBUG=0
SECRET_KEY=change-this-to-a-long-random-production-secret-key-at-least-50-chars
ALLOWED_HOSTS=example.com,www.example.com
CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com
SECURE_SSL_REDIRECT=1
SESSION_COOKIE_SECURE=1
CSRF_COOKIE_SECURE=1
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=1
SECURE_HSTS_PRELOAD=1
USE_X_FORWARDED_PROTO=1
DB_ENGINE=django.db.backends.postgresql
DB_NAME=journal_db
DB_USER=journal_user
DB_PASSWORD=change-this-password
DB_HOST=db
DB_PORT=5432
WAIT_FOR_DB=1
POSTGRES_DB=journal_db_pg
POSTGRES_USER=journal_user_pg
POSTGRES_PASSWORD=change-this-password
APP_IMAGE=ghcr.io/your-org-or-user/cadet_journal:latest
DJANGO_SUPERUSER_USERNAME=chiefadmin2026
DJANGO_SUPERUSER_EMAIL=admin.journal2026@example.com
DJANGO_SUPERUSER_PASSWORD=change-this-admin-password
DJANGO_SUPERUSER_ROTATE_PASSWORD=0
pas_key_data=change-this-data-tools-password
TRUST_X_FORWARDED_FOR=0
SSH_HOST=
SSH_USER=
SSH_PASSWORD=
SSH_PORT=22
REPO_URL=git@github.com:Pavel9876543/journal_cadet.git
APP_DIR=/opt/cadet_journal

# Не нужны
GHCR_PULL_USER=
GHCR_PULL_TOKEN=
